{
  "name": "@smounters/imperium",
  "version": "0.1.0",
  "description": "NestJS-like modular DI container with unified HTTP + Connect RPC server for TypeScript",
  "keywords": [
    "di",
    "dependency-injection",
    "fastify",
    "connectrpc",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./decorators": {
      "types": "./dist/decorators/index.d.ts",
      "import": "./dist/decorators/index.js"
    },
    "./pipes": {
      "types": "./dist/pipes/index.d.ts",
      "import": "./dist/pipes/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js"
    },
    "./ws": {
      "types": "./dist/ws/index.d.ts",
      "import": "./dist/ws/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smounters/imperium.git"
  },
  "bugs": {
    "url": "https://github.com/smounters/imperium/issues"
  },
  "homepage": "https://smounters.github.io/imperium/",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "clean": "rm -rf dist",
    "docs:dev": "pnpm exec vitepress dev docs",
    "docs:build": "pnpm exec vitepress build docs",
    "docs:preview": "pnpm exec vitepress preview docs",
    "prepack": "pnpm run clean && pnpm run build",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "peerDependencies": {
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-fastify": "^2.1.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.7.4",
    "reflect-metadata": "^0.2.2",
    "tslog": "^4.10.2",
    "tsyringe": "^4.10.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "@fastify/websocket": {
      "optional": true
    }
  },
  "devDependencies": {
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-fastify": "^2.1.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "fastify": "^5.8.4",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "tslog": "^4.10.2",
    "tsyringe": "^4.10.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "zod": "^4.3.6"
  }
}
