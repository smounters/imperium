{
  "name": "@smounters/imperium-cron",
  "version": "0.1.0",
  "description": "Cron scheduling for @smounters/imperium",
  "keywords": ["cron", "scheduler", "imperium", "nestjs-like", "typescript"],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smounters/imperium.git",
    "directory": "packages/imperium-cron"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepack": "pnpm run clean && pnpm run build",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "peerDependencies": {
    "@smounters/imperium": "^1.1.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@smounters/imperium": "workspace:*"
  },
  "dependencies": {
    "croner": "^10.0.1"
  }
}
