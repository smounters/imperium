{
  "name": "@smounters/imperium-events",
  "version": "0.1.1",
  "description": "Typed event emitter for @smounters/imperium",
  "keywords": ["events", "event-emitter", "imperium", "nestjs-like", "typescript"],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smounters/imperium.git",
    "directory": "packages/imperium-events"
  },
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepack": "pnpm run clean && pnpm run build",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "peerDependencies": {
    "@smounters/imperium": "^1.2.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@smounters/imperium": "workspace:*"
  }
}
